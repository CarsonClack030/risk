{
  "name": "risk-studio",
  "private": true,
  "version": "1.1.7",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --host 0.0.0.0 --port 1420",
    "dev:backend": "python3 backend/main.py --host 127.0.0.1 --port 38911",
    "build": "npm run build:sidecar && tauri build",
    "build:sidecar": "python3 backend/build_sidecar.py",
    "build:web": "vite build",
    "build:debug:app": "npm run build:sidecar && tauri build --debug -b app --no-sign",
    "build:release:app": "npm run build:sidecar && tauri build -b app",
    "build:release:dmg": "npm run build:sidecar && tauri build -b dmg",
    "build:release:windows": "tauri build -b nsis",
    "build:release:windows:msi": "tauri build -b msi",
    "build:release:full": "./build_release.sh",
    "lint": "npm run lint:frontend && npm run lint:python",
    "lint:frontend": "eslint src vite.config.js",
    "lint:python": "python3 -m ruff check backend/src backend/tests backend/*.py scripts/*.py",
    "format:frontend": "prettier --write \"src/**/*.{js,jsx,css}\" vite.config.js eslint.config.js",
    "format:python": "python3 -m ruff format backend/src backend/tests backend/*.py scripts/*.py",
    "test:frontend": "node --test src/*.test.js",
    "test:macos-bundle": "bash scripts/smoke_macos_bundle.sh",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "2.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.2",
    "vite": "^7.3.6"
  }
}
