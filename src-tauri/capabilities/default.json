{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main Risk Studio window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://github.com/CarsonClack030/risk/releases"
        },
        {
          "url": "https://github.com/CarsonClack030/risk/releases/**"
        },
        {
          "url": "https://github.com/carsonclack030/risk/releases/**"
        },
        {
          "url": "https://github.com/wangminglei030/risk/releases/**"
        }
      ]
    }
  ]
}
