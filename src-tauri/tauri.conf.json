{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Risk Studio",
  "version": "1.1.4",
  "identifier": "com.carson.riskstudio",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Risk Studio",
        "width": 1600,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "externalBin": [
      "../backend/bin/risk-backend"
    ]
  }
}
